{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "includes": ["**/*.md"],
  "excludes": [
    "**/node_modules",
    "**/CHANGELOG.md",
    "**/release-notes.md",
    "apm_modules/**",
    ".github/prompts/**",
    ".github/instructions/**",
    ".github/agents/**",
    ".github/chatmodes/**",
    ".claude/**",
    ".cursor/**",
    ".opencode/**",
    ".gemini/**",
    ".windsurf/**",
    ".kiro/**",
    ".agents/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.21.1.wasm"
  ]
}
